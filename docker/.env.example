# =============================================================================
# docker/.env.example
# Copy this to .env and fill in ALL values before running deploy.sh.
# NEVER commit .env to version control – it contains secrets.
# =============================================================================

# ── Domain ────────────────────────────────────────────────────────────────────
# Your Matrix homeserver domain (e.g. matrix.example.com or just example.com)
DOMAIN=matrix.example.com

# Email used for Let's Encrypt certificate notifications
LETSENCRYPT_EMAIL=admin@example.com

# ── Synapse secrets (generate with: openssl rand -hex 32) ─────────────────────
REGISTRATION_SHARED_SECRET=CHANGE_ME_openssl_rand_hex_32
MACAROON_SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
FORM_SECRET=CHANGE_ME_openssl_rand_hex_32

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_USER=synapse
POSTGRES_DB=synapse

# ── coturn TURN server ────────────────────────────────────────────────────────
# Shared secret between Synapse and coturn (generate with: openssl rand -hex 32)
COTURN_SECRET=CHANGE_ME_openssl_rand_hex_32

# ── LiveKit SFU ───────────────────────────────────────────────────────────────
# API key / secret pair for LiveKit (generate with: openssl rand -hex 16 / 32)
LIVEKIT_API_KEY=CHANGE_ME_livekit_api_key
LIVEKIT_API_SECRET=CHANGE_ME_openssl_rand_hex_32

# ── Deployment flags ──────────────────────────────────────────────────────────
# Set to "true" once you have SSL certificates from Let's Encrypt.
# Leave as "false" for the first deployment (HTTP-only testing).
SSL_ENABLED=false
