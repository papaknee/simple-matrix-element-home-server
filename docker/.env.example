# =============================================================================
# docker/.env.example
# Reference file showing all available settings.
#
# DO NOT edit this file directly. Instead, run:
#   ./init-env.sh
# It will ask for your domain, email, and DB password, then generate
# a complete .env with all secrets filled in automatically.
#
# NEVER commit .env to version control – it contains secrets.
# =============================================================================
#
# The values below are placeholders used by init-env.sh as a template reference.

# ── Domains ───────────────────────────────────────────────────────────────────
# Root DNS zone you control.
ROOT_DOMAIN=example.com

# Service hostnames (defaults should usually remain as shown below).
MATRIX_DOMAIN=matrix.example.com
ELEMENT_DOMAIN=element.example.com
LIVEKIT_DOMAIN=livekit.example.com
TURN_DOMAIN=turn.example.com

# Email used for Let's Encrypt certificate notifications
LETSENCRYPT_EMAIL=admin@example.com

# ── Synapse secrets (generate with: openssl rand -hex 32) ─────────────────────
REGISTRATION_SHARED_SECRET=CHANGE_ME_openssl_rand_hex_32
MACAROON_SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
FORM_SECRET=CHANGE_ME_openssl_rand_hex_32

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_USER=synapse
POSTGRES_DB=synapse

# ── coturn TURN server ────────────────────────────────────────────────────────
# Shared secret between Synapse and coturn (generate with: openssl rand -hex 32)
COTURN_SECRET=CHANGE_ME_openssl_rand_hex_32

# ── LiveKit SFU ───────────────────────────────────────────────────────────────
# API key / secret pair for LiveKit (generate with: openssl rand -hex 16 / 32)
LIVEKIT_API_KEY=CHANGE_ME_livekit_api_key
LIVEKIT_API_SECRET=CHANGE_ME_openssl_rand_hex_32

# ── Deployment flags ──────────────────────────────────────────────────────────
# Set to "true" once you have SSL certificates from Let's Encrypt.
# Leave as "false" for the first deployment (HTTP-only testing).
SSL_ENABLED=false
